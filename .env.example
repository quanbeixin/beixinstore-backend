# 服务器配置
PORT=3000

# 数据库配置（阿里云 RDS MySQL）
DB_HOST=your-rds-host.aliyuncs.com
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_db_name

# JWT 配置
JWT_SECRET=your_super_secret_key_change_this_in_production
JWT_EXPIRES_IN=7d

# 前端地址（CORS 白名单）
CLIENT_ORIGIN=http://localhost:5173
