# Server configuration
PORT=3000
HOST=0.0.0.0

# Database configuration (Alibaba Cloud RDS MySQL)
DB_HOST=your-rds-host.aliyuncs.com
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_db_name

# JWT configuration
JWT_SECRET=your_super_secret_key_change_this_in_production
JWT_EXPIRES_IN=7d

# CORS allowed origins (comma-separated)
# Example: http://localhost:5173,http://39.97.253.194
CLIENT_ORIGIN=http://localhost:5173

# Request log options
# true: include OPTIONS preflight logs
# false: hide OPTIONS preflight logs (default behavior)
LOG_OPTIONS_REQUESTS=false

# Reverse proxy support for real client IP (recommended when using Nginx)
# false/0: disabled
# 1/true: trust one proxy hop
TRUST_PROXY=1

# API rate limit (default: 15min / 1000 requests)
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX=1000
# Whether to skip OPTIONS preflight requests in API limiter
API_RATE_LIMIT_SKIP_OPTIONS=true
# Whether to exclude /api/auth/login from generic API limiter (login has dedicated limiter)
API_RATE_LIMIT_SKIP_LOGIN=true

# Login rate limit (default: 15min / 20 attempts)
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX=20

# Alibaba Cloud OSS configuration for Bug attachments
# Fill these values when enabling direct upload
ALIYUN_OSS_ACCESS_KEY_ID=
ALIYUN_OSS_ACCESS_KEY_SECRET=
ALIYUN_OSS_BUCKET=
ALIYUN_OSS_ENDPOINT=
ALIYUN_OSS_REGION=

# Optional public URL prefix. If empty, defaults to https://<bucket>.<endpoint>
ALIYUN_OSS_PUBLIC_BASE_URL=

# Optional upload controls
ALIYUN_OSS_UPLOAD_DIR=beixin-store
ALIYUN_OSS_EXPIRE_SECONDS=300
ALIYUN_OSS_MAX_FILE_SIZE=10485760

# Optional STS token when temporary credentials are used
ALIYUN_OSS_SECURITY_TOKEN=
