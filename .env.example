# Server configuration
PORT=3000
HOST=0.0.0.0

# Database configuration (Alibaba Cloud RDS MySQL)
DB_HOST=your-rds-host.aliyuncs.com
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_db_name

# JWT configuration
JWT_SECRET=your_super_secret_key_change_this_in_production
JWT_EXPIRES_IN=7d

# CORS allowed origins (comma-separated)
# Example: http://localhost:5173,http://39.97.253.194
CLIENT_ORIGIN=http://localhost:5173

# Request log options
# true: include OPTIONS preflight logs
# false: hide OPTIONS preflight logs (default behavior)
LOG_OPTIONS_REQUESTS=false

# Legacy bootstrap
# true: allow server startup to auto-create legacy project-management tables and permissions
# false: require schema changes to go through sql/migrations
ENABLE_LEGACY_BOOTSTRAP=false
