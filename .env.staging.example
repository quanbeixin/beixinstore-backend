# Runtime configuration
NODE_ENV=production
APP_ENV=staging
PORT=3001
HOST=0.0.0.0

# Database configuration
DB_HOST=your-staging-rds-host.aliyuncs.com
DB_PORT=3306
DB_USER=your_staging_user
DB_PASSWORD=your_staging_password
DB_NAME=your_staging_db_name
DB_TIME_ZONE=+08:00

# JWT configuration
JWT_SECRET=replace_with_a_dedicated_staging_secret
JWT_EXPIRES_IN=7d

# CORS allowed origins (comma-separated)
CLIENT_ORIGIN=https://staging.your-domain.com,http://localhost:5173

# Request log options
LOG_OPTIONS_REQUESTS=false

# Legacy bootstrap
ENABLE_LEGACY_BOOTSTRAP=false
