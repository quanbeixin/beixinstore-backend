{
  "name": "admin-backend",
  "version": "1.0.0",
  "description": "Node.js + Express 管理后台后端服务",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "start:staging": "set APP_ENV=staging&& node server.js",
    "start:prod": "set APP_ENV=production&& node server.js",
    "migrate": "node scripts/runMigrations.js",
    "migrate:dry-run": "node scripts/runMigrations.js --dry-run",
    "migrate:staging": "set APP_ENV=staging&& node scripts/runMigrations.js",
    "migrate:staging:dry-run": "set APP_ENV=staging&& node scripts/runMigrations.js --dry-run",
    "migrate:prod": "set APP_ENV=production&& node scripts/runMigrations.js",
    "migrate:prod:dry-run": "set APP_ENV=production&& node scripts/runMigrations.js --dry-run",
    "deploy:staging": "powershell -ExecutionPolicy Bypass -File ./scripts/deploy-staging.ps1",
    "deploy:production": "powershell -ExecutionPolicy Bypass -File ./scripts/deploy-production.ps1",
    "pm2:start": "pm2 start ecosystem.config.js --only admin-backend",
    "pm2:start:staging": "pm2 start ecosystem.config.js --only admin-backend-staging",
    "pm2:stop": "pm2 stop admin-backend",
    "pm2:restart": "pm2 restart admin-backend",
    "pm2:restart:staging": "pm2 restart admin-backend-staging",
    "pm2:delete": "pm2 delete admin-backend",
    "pm2:delete:staging": "pm2 delete admin-backend-staging",
    "pm2:logs": "pm2 logs admin-backend",
    "pm2:logs:staging": "pm2 logs admin-backend-staging",
    "pm2:monit": "pm2 monit"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.9.2"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}
